{
  "name": "@sil/color",
  "version": "0.5.0",
  "description": "Type-safe color conversion and utilities for TypeScript/JavaScript",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "files": [
    "dist/esm",
    "dist/cjs",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "jest",
    "example:basic": "ts-node examples/basic.ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/sil-color.git",
    "directory": "packages/color"
  },
  "homepage": "https://github.com/silvandiepen/sil-color#readme",
  "bugs": {
    "url": "https://github.com/silvandiepen/sil-color/issues"
  },
  "keywords": [
    "color",
    "colors",
    "convert",
    "hsl",
    "rgb",
    "hex",
    "hsv",
    "cmyk",
    "typescript"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "babel-jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
